# Server Configuration
NODE_ENV=development
PORT=3000
API_BASE_URL=http://localhost:3000

# Database Configuration
DATABASE_URL=postgresql://localhost:5432/samarthbharat
MONGODB_URI=mongodb://localhost:27017/samarthbharat
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# AWS Bedrock (Claude AI) - CRITICAL
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_aws_access_key_here
AWS_SECRET_ACCESS_KEY=your_aws_secret_key_here

# Google Cloud (Speech & Translation) - CRITICAL
GOOGLE_CREDENTIALS_PATH=./google-credentials.json

# Twilio (WhatsApp, SMS, Voice) - CRITICAL
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1234567890
TWILIO_WHATSAPP_NUMBER=+14155238886

# External APIs
OPENWEATHER_API_KEY=your_openweather_api_key

# JWT Configuration
JWT_SECRET=change-this-to-a-random-secret-key-min-32-chars
JWT_EXPIRES_IN=30m
REFRESH_TOKEN_SECRET=change-this-to-another-random-secret-key-min-32-chars
REFRESH_TOKEN_EXPIRES_IN=7d

# Security
BCRYPT_ROUNDS=10
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:5173

# Logging
LOG_LEVEL=info
